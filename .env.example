# ============================================================
# LLM的基础配置
# 用哪个 LLM？复制一份为 .env 然后填你的配置
# ============================================================

# 方案A：OpenAI 官方或兼容接口（推荐入门用）
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 方案B：DeepSeek（国内友好）
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# ============================================================
# 上下文窗口（可选，不填则自动匹配）
# ============================================================
# Uki 会按以下优先级查找窗口大小：
#   1. 下面三个手动值（你填了就优先用）
#   2. OpenRouter API 缓存（启动时自动拉取 500+ 模型数据）
#   3. 代码内置字典（DeepSeek/GPT/Claude 等常见模型）
#   4. 保守默认 16K
#
# 一般不需要改。只有当你发现 Uki 匹配错了，或者用了极新的模型时：
# UKI_CONTEXT_WINDOW=1000000   # 模型总窗口（token 数）
# UKI_CONTEXT_MAX=800000       # 触发警告的上限，建议设 80%
# UKI_CONTEXT_TRIM=600000      # 触发强制裁剪的阈值，建议设 60%
# UKI_SUMMARY_THRESHOLD=8000   # 对话历史超过此 token 数时自动总结（默认自动计算）
#
# 示例：手动适配一个冷门模型
# UKI_CONTEXT_WINDOW=32768
# UKI_CONTEXT_MAX=26000
# UKI_CONTEXT_TRIM=20000


# ============================================================
# 开发时期的Git状态
# ============================================================
# 设为 1 时在对话中注入 Git 状态（开发时建议开启）
# UKI_GIT_CONTEXT=1